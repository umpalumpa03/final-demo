    "accordionContent": [
      {
        "title": "What is this component library?",
        "content":
        "This is a comprehensive UI component library built with Angular, providing reusable and accessible components for building modern web applications. It includes buttons, forms, navigation, and many other essential UI elements."
      },
      {
        "title": "How do I use these components?",
        "content":
          "Each component can be imported directly into your Angular application. Simply import the component, add it to your template, and configure it using the provided inputs and outputs. Documentation and examples are available for each component."
      },
      {
        "title": "Are these components accessible?",
        "content":
          "Yes, all components are built with accessibility in mind, following WCAG guidelines. They include proper ARIA attributes, keyboard navigation support, and screen reader compatibility to ensure an inclusive user experience."
      },
      {
        "title": "Can I customize the styling?",
        "content":
          "Absolutely! Components support theme customization through CSS variables and custom styling. You can override default styles using SCSS mixins and apply your brand colors to match your design system."
      },
      {
        "title": "Can I customize the styling?",
        "content":
          "Absolutely! Components support theme customization through CSS variables and custom styling. You can override default styles using SCSS mixins and apply your brand colors to match your design system."
      }
    ],
    "multiAccordionContent": [
      {
        "title": "Features",
        "content":
          "Our component library includes over 50 pre-built components, dark mode support, responsive design, TypeScript support, comprehensive documentation, and regular updates with new features and improvements."
      },
      {
        "title": "Installation",
        "content":
          "Install the library using npm or yarn package manager. Import the required modules in your Angular application, configure the theme settings, and start using components in your templates immediately."
      },
      {
        "title": "Documentation",
        "content":
          "Complete documentation is available online, including API references, usage examples, best practices, and migration guides. Each component has detailed documentation with live demos and code snippets."
      }
    ],
    "collapsibleContent": [
      {
        "title": "Click To Expand",
        "content":
          "This collapsible section contains additional information that can be shown or hidden by clicking the header. It's useful for organizing content and improving page readability."
